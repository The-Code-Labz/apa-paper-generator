# ==============================================================================
# APA 7th Edition Paper Generator — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ==============================================================================

# Void AI API key (https://api.voidai.app)
SHARED_VOID_API_FREE_KEY=sk-your-key-here

# AI model to use
APA_MODEL=gpt-4o

# API base URL
# Default: Void AI direct
# Optional: point at a LiteLLM proxy for routing through internal providers
VOID_API_BASE=https://api.voidai.app/v1
# VOID_API_BASE=http://your-litellm-host:4000
